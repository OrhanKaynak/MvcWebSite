@model IEnumerable<MvcWebSite.Core.Entities.User>

@{
    ViewData["Title"] = "Kullanıcılar";
}

<h1>Kullanıcılar</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Yeni Ekle</a>
</p>

<table class="table table-hover table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Kullanıcı Adı</th>
            <th>Email</th>
            <th>Ad</th>
            <th>Soyad</th>
            <th>Kayıt Tarihi</th>
            <th>Durum</th>
            <th>Admin</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @if (Model != null)
    {
        foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.UserName</td>
                <td>@item.Email</td>
                <td>@item.Name</td>
                <td>@item.Surname</td>
                <td>@item.CreateDate.ToString("g")</td>
                <td>@(item.IsActive ? "Aktif" : "Pasif")</td>
                <td>@(item.IsAdmin ? "Evet" : "Hayır")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Düzenle</a> ||
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Sil</a>
                </td>
            </tr>
        }
    }
    </tbody>
</table>
