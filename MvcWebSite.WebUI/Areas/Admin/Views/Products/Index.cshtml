@model IEnumerable<MvcWebSite.Core.Entities.Product>

@{
    ViewData["Title"] = "Ürünler";
}

<h1>Ürünler</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Yeni Ekle</a>
</p>

<table class="table table-hover table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Ürün Adı</th>
            <th>Resim</th>
            <th>Kayıt Tarihi</th>
            <th>Durum</th>
            <th>Anasayfa</th>
            <th>Stok</th>
            <th>Fiyat</th>
            <th>Kategori</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @if (Model != null)
    {
        foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>
                    @if (!string.IsNullOrEmpty(item.Image))
                    {
                        <img src="@item.Image" alt="@item.Name" style="max-height:50px;" />
                    }
                </td>
                <td>@item.CreateDate.ToString("g")</td>
                <td>@(item.IsActive ? "Aktif" : "Pasif")</td>
                <td>@(item.IsHome ? "Evet" : "Hayır")</td>
                <td>@item.Stock</td>
                <td>@item.Price.ToString("C")</td>
                <td>@item.Category?.Name</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Düzenle</a> ||
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Sil</a>
                </td>
            </tr>
        }
    }
    </tbody>
</table>
