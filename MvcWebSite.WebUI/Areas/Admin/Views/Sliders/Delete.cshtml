@model MvcWebSite.Core.Entities.Slider

@{
    ViewData["Title"] = "Sil";
}

<h1>Delete</h1>

<h3>Kayıt silinsin mi?</h3>
<div>
    <h4>Slider</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Id</dt>
        <dd class="col-sm-10">@Model.Id</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Title)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Title)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Description)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Description)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Image)</dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Image)
            @if (!string.IsNullOrEmpty(Model?.Image))
            {
                <div class="mt-2">
                    <img src="@Url.Content(Model.Image)" alt="@Model.Title" style="max-width:200px;max-height:200px;" />
                </div>
            }
        </dd>
    </dl>
</div>

<form asp-area="Admin" asp-controller="Sliders" asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Sil" class="btn btn-danger" />
    <a asp-area="Admin" asp-controller="Sliders" asp-action="Index" class="btn btn-secondary">Listeye dön</a>
</form>
